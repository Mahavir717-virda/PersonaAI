APP_NAME=PersonaAI
APP_VERSION=1.0.0-alpha
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
API_V2_PREFIX=/api/v2

DATABASE_URL=postgresql+asyncpg://personaai:personaai_password@localhost:5432/personaai
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_CONNECT_TIMEOUT_SECONDS=2.0

CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://persona-ai-nine-peach.vercel.app
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_EXPOSE_HEADERS=X-Request-ID,X-Correlation-ID,X-Process-Time

LOG_LEVEL=INFO
LOG_FILE=logs/personaai.log
LOG_JSON=true

CREDENTIAL_ENCRYPTION_SECRET=replace_with_a_long_random_secret

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_HEALTH_PATH=/api/tags
HEALTH_CHECK_TIMEOUT_SECONDS=1.0

GROQ_API_KEY = Your_API_Key
AI_PROVIDER=ANY_YOU_LIKE
AI_MODEL=Model_name

VITE_GOOGLE_CLIENT_ID=your_google_client_id

POSTGRES_USER=personaai
POSTGRES_PASSWORD=personaai_password
POSTGRES_DB=personaai
POSTGRES_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@personaai.local
PGADMIN_DEFAULT_PASSWORD=personaai_admin_password
PGADMIN_PORT=5050

OLLAMA_PORT=11434

